{
  "schema_version": "1.0",
  "allowed_roots": [
    "/data/raw"
  ],
  "limits": {
    "max_depth": 6,
    "max_entries": 100000,
    "max_runtime_seconds": 300,
    "max_request_bytes": 1048576,
    "max_response_bytes": 10485760,
    "max_paths": 10000,
    "max_path_bytes": 4096
  },
  "follow_symlinks": false,
  "allow_mount_crossing": false
}
