{
  "$id": "https://github.com/LyuWeiBio/easy_pipe/schemas/v1/AuditEvent.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "One append-only, non-sensitive audit record.",
  "properties": {
    "actor": {
      "title": "Actor",
      "type": "string"
    },
    "event_id": {
      "format": "uuid",
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "title": "Event Type",
      "type": "string"
    },
    "input_hashes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Input Hashes",
      "type": "object"
    },
    "output_hashes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Output Hashes",
      "type": "object"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "started",
        "success",
        "failed",
        "blocked"
      ],
      "title": "Status",
      "type": "string"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "timestamp",
    "event_type",
    "project_id",
    "actor",
    "status",
    "summary"
  ],
  "title": "AuditEvent",
  "type": "object",
  "x-biopipe-schema-version": "1.0"
}
