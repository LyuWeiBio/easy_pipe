{
  "$defs": {
    "ProbeConfiguration": {
      "additionalProperties": false,
      "description": "Bounded, fail-closed defaults for the fixed Remote Probe.",
      "properties": {
        "follow_symlinks": {
          "default": false,
          "title": "Follow Symlinks",
          "type": "boolean"
        },
        "max_depth": {
          "default": 6,
          "maximum": 64,
          "minimum": 0,
          "title": "Max Depth",
          "type": "integer"
        },
        "max_entries": {
          "default": 100000,
          "maximum": 10000000,
          "minimum": 1,
          "title": "Max Entries",
          "type": "integer"
        },
        "max_paths": {
          "default": 10000,
          "maximum": 100000,
          "minimum": 1,
          "title": "Max Paths",
          "type": "integer"
        },
        "max_request_bytes": {
          "default": 1048576,
          "maximum": 16777216,
          "minimum": 1024,
          "title": "Max Request Bytes",
          "type": "integer"
        },
        "max_response_bytes": {
          "default": 10485760,
          "maximum": 104857600,
          "minimum": 1024,
          "title": "Max Response Bytes",
          "type": "integer"
        },
        "max_runtime_seconds": {
          "default": 300,
          "maximum": 3600,
          "minimum": 1,
          "title": "Max Runtime Seconds",
          "type": "integer"
        },
        "remote_path": {
          "default": "~/.local/bin/bioprobe.pyz",
          "title": "Remote Path",
          "type": "string"
        },
        "stderr_limit_bytes": {
          "default": 4096,
          "maximum": 1048576,
          "minimum": 256,
          "title": "Stderr Limit Bytes",
          "type": "integer"
        }
      },
      "title": "ProbeConfiguration",
      "type": "object"
    },
    "SourcePrivacy": {
      "additionalProperties": false,
      "description": "Privacy defaults for source metadata.",
      "properties": {
        "allow_external_llm": {
          "default": false,
          "title": "Allow External Llm",
          "type": "boolean"
        },
        "filenames_sensitive": {
          "default": true,
          "title": "Filenames Sensitive",
          "type": "boolean"
        }
      },
      "title": "SourcePrivacy",
      "type": "object"
    }
  },
  "$id": "https://github.com/LyuWeiBio/easy_pipe/schemas/v1/SourceProfile.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A reference to existing SSH configuration; it never stores credentials.",
  "properties": {
    "allowed_roots": {
      "items": {
        "type": "string"
      },
      "maxItems": 1024,
      "minItems": 1,
      "title": "Allowed Roots",
      "type": "array"
    },
    "port": {
      "anyOf": [
        {
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Port"
    },
    "privacy": {
      "$ref": "#/$defs/SourcePrivacy"
    },
    "probe": {
      "$ref": "#/$defs/ProbeConfiguration"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "ssh_alias": {
      "title": "Ssh Alias",
      "type": "string"
    },
    "username": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Username"
    }
  },
  "required": [
    "source_id",
    "ssh_alias",
    "allowed_roots"
  ],
  "title": "SourceProfile",
  "type": "object",
  "x-biopipe-schema-version": "1.0"
}
